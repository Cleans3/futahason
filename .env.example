# ─────────────────────────────────────────────────────────────────────────────
# futahason.com E2E — environment configuration
# Copy to ".env" and fill in. NEVER commit the real ".env".
# ─────────────────────────────────────────────────────────────────────────────

# Base URL under test (override to point at a staging environment if available)
BASE_URL=https://futahason.com

# --- Login (OTP) test account -------------------------------------------------
# A real Vietnamese mobile number registered for a TEST account.
# Login is OTP-only: a code is delivered by SMS/Zalo, so a human (or an SMS-API
# bridge) is required to complete TC-LOGIN-08. Leave blank to run only the
# automatable login steps (modal + validation + OTP request).
TEST_PHONE=
TEST_COUNTRY_CODE=+84

# --- Authenticated booking / payment tests ------------------------------------
# The payment-information page is gated behind OTP login. Authenticated payment
# tests (TC-PAY-08..10) only run when a saved session exists at auth/user.json.
# Generate it once with:  npm run auth:setup   (an operator types the OTP).
STORAGE_STATE=auth/user.json

# ⚠️ Production-safety switch. The suite NEVER submits a real payment.
# Keep this false on production. Only set true against a staging/sandbox env
# that uses a test payment gateway.
ALLOW_REAL_BOOKING=false
